// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  results     TestResult[]
  lifeEvents  LifeEvent[]
  reportUsage ReportUsage[]
}

model TestResult {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  // MBTI 维度得分
  eScore Float // 0-100
  nScore Float // 0-100
  tScore Float // 0-100
  jScore Float // 0-100

  // 计算得出的人格类型
  mbtiType String // 如 "INTJ"

  // 原始答案（可选）
  answers Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lifeEvents LifeEvent[]
  reports    Report[]
}

model LifeEvent {
  id       Int         @id @default(autoincrement())
  userId   Int
  user     User        @relation(fields: [userId], references: [id])
  resultId Int?
  result   TestResult? @relation(fields: [resultId], references: [id])

  eventType           String // career/relationship/health/etc
  eventCategory       String?
  title               String
  description         String?
  eventDate           DateTime
  expectedImpact      String? // positive/negative/neutral
  actualImpactScore   Float? // -100 to 100
  relatedDimension    String? // E/N/T/J
  correlationAnalyzed Boolean  @default(false)
  correlationNote     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([resultId])
  @@index([eventType])
  @@index([eventDate])
}

model Report {
  id       Int        @id @default(autoincrement())
  resultId Int
  result   TestResult @relation(fields: [resultId], references: [id])

  reportType     String // basic/pro/master
  content        String @db.Text
  tokens         Int
  generationTime Int // 毫秒
  requestId      String @unique
  cost           Float // 人民币

  status       String @default("completed") // pending/completed/failed
  qualityScore Float? // 1-5

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resultId])
  @@index([reportType])
  @@index([status])
}

model ReportUsage {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  date  DateTime @db.Date
  count Int      @default(0)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model CostRecord {
  id Int @id @default(autoincrement())

  timestamp  DateTime @default(now())
  cost       Float // 美元
  model      String
  reportType String
  userId     String

  @@index([timestamp])
  @@index([userId])
}

model RateLimit {
  id Int @id @default(autoincrement())

  identifier String   @unique // userId 或 IP
  type       String // user/ip
  count      Int      @default(0)
  resetTime  DateTime

  @@index([type])
  @@index([resetTime])
}
