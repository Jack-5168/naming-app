// 简化版 Schema - 用于快速部署测试
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              Int           @id @default(autoincrement())
  wechatOpenid    String        @unique
  nickname        String?
  avatar          String?
  membershipLevel String        @default("free")
  testCount       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  testResults     TestResult[]
  reports         Report[]
}

model Question {
  id              Int          @id @default(autoincrement())
  text            String       @db.Text
  dimension       String
  difficulty      Float        @default(0.5)
  discrimination  Float        @default(1.0)
  isActive        Boolean      @default(true)
  
  options         QuestionOption[]
  responses       Response[]
}

model QuestionOption {
  id              Int          @id @default(autoincrement())
  questionId      Int
  question        Question     @relation(fields: [questionId], references: [id])
  text            String       @db.Text
  score           Int
}

model Response {
  id              Int          @id @default(autoincrement())
  questionId      Int
  question        Question     @relation(fields: [questionId], references: [id])
  optionId        Int
  option          QuestionOption @relation(fields: [optionId], references: [id])
  timeSpent       Int
}

model TestResult {
  id              Int          @id @default(autoincrement())
  userId          Int
  user            User         @relation(fields: [userId], references: [id])
  eScore          Float        @default(50)
  nScore          Float        @default(50)
  tScore          Float        @default(50)
  jScore          Float        @default(50)
  mbtiType        String
  stabilityIndex  Float        @default(0.5)
  answers         Json?
  createdAt       DateTime     @default(now())

  reports         Report[]
}

model Report {
  id              Int          @id @default(autoincrement())
  resultId        Int
  result          TestResult   @relation(fields: [resultId], references: [id])
  reportType      String
  content         Json
  createdAt       DateTime     @default(now())
}
