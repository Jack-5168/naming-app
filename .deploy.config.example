# =============================================================================
# 服务器部署配置文件
# =============================================================================
# 使用说明:
# 1. 复制此文件为 .deploy.config
# 2. 修改以下配置为您的实际服务器信息
# 3. 运行 ./deploy.sh 进行部署
# =============================================================================

# 服务器 SSH 用户名
SERVER_USER="root"

# 服务器 IP 地址或域名
SERVER_HOST="your-server-ip.com"

# SSH 端口（默认 22）
SERVER_PORT="22"

# 部署目标路径
SERVER_PATH="/var/www/naming-app"

# =============================================================================
# 示例配置:
# =============================================================================
# 阿里云服务器:
# SERVER_USER="root"
# SERVER_HOST="47.100.xx.xx"
# SERVER_PORT="22"
# SERVER_PATH="/var/www/naming-app"
#
# 腾讯云服务器:
# SERVER_USER="ubuntu"
# SERVER_HOST="129.204.xx.xx"
# SERVER_PORT="22"
# SERVER_PATH="/home/ubuntu/naming-app"
# =============================================================================
